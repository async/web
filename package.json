{
  "name": "async-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Async web framework and request/runtime/provider graph packages.",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm --dir packages/router build && pnpm --dir packages/webruntime build && pnpm --dir packages/web build",
    "lint": "pnpm -r lint",
    "pipeline:api-surface": "async-pipeline run-task api-surface",
    "pipeline:api:surface:generate": "async-pipeline run-task api-ledger",
    "pipeline:github:check": "async-pipeline github check",
    "pipeline:github:generate": "async-pipeline github generate",
    "pipeline:main-snapshot": "async-pipeline run main-snapshot",
    "pipeline:pages": "async-pipeline run-task docs.site",
    "pipeline:publish:github:main": "async-pipeline publish github main --package packages/web",
    "pipeline:publish:github:pr": "async-pipeline publish github pr --package packages/web",
    "pipeline:publish:github:release": "async-pipeline publish github release --package packages/web",
    "pipeline:publish:npm": "async-pipeline publish npm --package packages/web",
    "pipeline:release-doctor": "async-pipeline run release-doctor",
    "pipeline:release:doctor": "async-pipeline release doctor --package packages/web",
    "pipeline:release:ensure": "async-pipeline release ensure --package packages/web",
    "pipeline:stable-release": "async-pipeline run stable-release",
    "pipeline:sync:check": "async-pipeline sync check",
    "pipeline:sync:generate": "async-pipeline sync generate",
    "pipeline:task:api-ledger": "async-pipeline run-task api-ledger",
    "pipeline:task:api-surface": "async-pipeline run-task api-surface",
    "pipeline:task:docs.site": "async-pipeline run-task docs.site",
    "pipeline:task:pack": "async-pipeline run-task pack",
    "pipeline:verify": "async-pipeline run verify",
    "pipeline:verify:force": "async-pipeline run verify --force",
    "release:check": "pnpm run pipeline:verify:force",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@async/api-contract": "0.1.0",
    "@async/pipeline": "0.8.9"
  }
}
