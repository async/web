{
  "name": "@async/router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pure structured route specs and composition helpers for Async Web.",
  "license": "MIT",
  "homepage": "https://github.com/async-framework/async-web/tree/main/packages/router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/async-framework/async-web.git",
    "directory": "packages/router"
  },
  "bugs": {
    "url": "https://github.com/async-framework/async-web/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
