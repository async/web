{
  "name": "@async/webruntime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Request-to-Response web runtime graph with route middleware, scoped platform APIs, cache stores, and provider extension points.",
  "license": "MIT",
  "homepage": "https://github.com/async/web/tree/main/packages/webruntime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/async/web.git",
    "directory": "packages/webruntime"
  },
  "bugs": {
    "url": "https://github.com/async/web/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./async-db": {
      "types": "./dist/async-db/index.d.ts",
      "default": "./dist/async-db/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./node/mini-cloudflare": {
      "types": "./dist/node/create-mini-cloudflare-preview-server.d.ts",
      "default": "./dist/node/create-mini-cloudflare-preview-server.js"
    },
    "./edge": {
      "types": "./dist/edge/index.d.ts",
      "default": "./dist/edge/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "default": "./dist/platform/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "default": "./dist/routes.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "default": "./dist/tracing/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && vite build && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "happy-dom": "20.9.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
